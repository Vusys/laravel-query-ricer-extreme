{
    $schema: "vendor/infection/infection/resources/schema.json",
    source: {
        directories: ["src"],
    },
    timeout: 30,
    logs: {
        text: "build/infection/infection.log",
        html: "build/infection/infection.html",
        json: "build/infection/infection.json",
        summary: "build/infection/summary.log",
        github: true,
        stryker: {
            report: "master",
        },
    },
    mutators: {
        "@default": true,
        // version is an internal counter never asserted in tests — not semantically observable
        "Increment": {
            "ignoreSourceCodeByRegex": ["->version\\+\\+"]
        },
        // isset() returns true for any non-null value, so true vs false is unobservable here
        "TrueValue": {
            "ignoreSourceCodeByRegex": [
                ".*absent\\[\\$mapKey\\] = true.*",
                ".*absent\\[\\$journalEntry->entryKey\\] = true.*",
                // UniqueKeyIndex::recordAbsent — absent[] is only ever read via isset()
                ".*\\$this->absent\\[\\$uniqueFingerprint\\] = true.*",
                // UniqueKeyIndex::uniqueIndexesForModelClass — $seen[] is only ever read via isset()
                ".*\\$seen\\[\\$key\\] = true.*",
                // UniqueKeyIndex::markDiscovered — discoveredClasses[] is only ever read via isset() in hasDiscovered()
                ".*\\$this->discoveredClasses\\[\\$modelClass\\] = true.*",
            ]
        },
        // break vs continue after $found = true are equivalent — $found cannot be unset by remaining iterations
        "Break_": {
            "ignoreSourceCodeByRegex": ["break;"]
        },
        // HasIdentityMap: restored() listener is redundant — restore() calls save() internally which fires saved,
        // so afterSaved() already runs via the saved listener regardless. Removing restored() is a no-op.
        "MethodCallRemoval": {
            "ignoreSourceCodeByRegex": [
                "static::restored",
                "static::forceDeleted",
                "->afterForceDeleted\\(\\$model\\)"
            ]
        },
        // HasIdentityMap: registering forceDeleted only for SoftDeletes models — negating the guard registers
        // the listener on all models, but forceDeleted event never fires for non-SoftDeletes models so it is harmless.
        "IfNegation": {
            "ignoreSourceCodeByRegex": ["class_uses_recursive\\(static::class\\)"]
        },
        // CoverageRegistry::flushModelClass uses array_values(array_filter(...)).
        // Removing array_values produces a sparse array but foreach/count are unaffected — no observable difference.
        "UnwrapArrayValues": {
            "ignoreSourceCodeByRegex": [".*array_values\\(array_filter\\(.*"]
        },
        // Cache-key concatenations: SchemaDiscovery::cacheKey and MemoryBelongsToMany::resolveInverseRelationName
        // build per-(class,connection,table) / (related,parent,pivot) cache keys. Any consistent encoding that
        // remains unique per tuple keeps the cache correct, so dropping a separator, reordering operands, or
        // swapping the coalesce default produces a still-unique key for the single tuple any one test exercises.
        // Killing these would require tests that explicitly probe two tuples differing in just one slot.
        "Concat": {
            "ignoreSourceCodeByRegex": [
                ".*\\$modelClass[\\s.]*'@'[\\s.]*\\(\\$connectionName \\?\\? '__default__'\\).*",
                ".*\\$cacheKey = \\$relatedClass[\\s.]*'\\|'[\\s.]*\\$parentClass.*"
            ]
        },
        "ConcatOperandRemoval": {
            "ignoreSourceCodeByRegex": [
                ".*\\$modelClass[\\s.]*'@'[\\s.]*\\(\\$connectionName \\?\\? '__default__'\\).*",
                ".*\\$cacheKey = \\$relatedClass[\\s.]*'\\|'[\\s.]*\\$parentClass.*"
            ]
        },
        "Coalesce": {
            "ignoreSourceCodeByRegex": [
                ".*\\$modelClass[\\s.]*'@'[\\s.]*\\(\\$connectionName \\?\\? '__default__'\\).*"
            ]
        },
        // IdentityMapBuilder::getModels — ArrayOneItem on the final `return $models` after SQL.
        // The identity map entry always shadows the absent record for a model found by SQL;
        // killing this would require asserting the raw SQL result count before coverage is recorded.
        "ArrayOneItem": {
            "ignoreSourceCodeByRegex": ["return \\$models;"]
        },
        // pluck/first neededColumns/resolvedColumns — removing a column from the satisfies-check array
        // is only observable when the identity map entry has partial column knowledge, which no test exercises.
        // Correctness falls back to SQL when satisfies() fails.
        //
        // sum/min/max/avg [$column] → [] — same equivalence: the partial-coverage entry overwrites the
        // in-map model with un-loaded attributes (IdentityMapStore::remember sets $entry->model = $model),
        // so getAttribute($column) returns null and the !is_int && !is_float type guard one layer below
        // catches the fallthrough. The satisfies-check column is redundant given the type guard.
        "ArrayItemRemoval": {
            "ignoreSourceCodeByRegex": [
                ".*is_string\\(\\$key\\) \\? \\[\\$column, \\$key\\].*",
                ".*is_array\\(\\$columns\\) \\? \\$columns : \\[\\$columns\\].*",
                ".*getModelsFromCoverage\\(\\[\\$column\\].*"
            ]
        },
        // ModelIdentity::key — implode() handles int|string natively, so the explicit (string) cast on
        // $primaryKeyValue is defensive and produces identical output without it.
        "CastString": {
            "ignoreSourceCodeByRegex": [
                ".*\\(string\\) \\$this->primaryKeyValue.*"
            ]
        },
        // ConservativeSemantics::compare — the early `$left === null || $right === null` guard is a
        // fast-path duplicate. Mutating to `&&` leaves behavior unchanged because (a) for equality ops,
        // the gettype() mismatch check returns Unknown for mixed null/non-null anyway, and (b) for
        // ordered ops, the `(!is_int && !is_float) || ...` type guard in compareOrdered() catches null.
        // Keep the early guard for readability; document the mutant as behaviorally equivalent.
        "LogicalOr": {
            "ignoreSourceCodeByRegex": [
                ".*if \\(\\$left === null \\|\\| \\$right === null\\).*"
            ]
        },
        // ConservativeSemantics::compareForOrder / compareOrdered — `!is_int(x) && !is_float(x)` is the
        // pair of mutually-exclusive predicates for "x is not numeric". Negating ALL sub-expressions on
        // one half yields `is_int(x) && is_float(x)`, which is always false (a value cannot be both),
        // so that disjunct collapses out and the remaining half still catches every problematic case.
        // The other half's mutation is killed by the asymmetric-type tests in ConservativeSemanticsTest.
        "LogicalAndAllSubExprNegation": {
            "ignoreSourceCodeByRegex": [
                ".*! is_int\\(\\$left\\) && ! is_float\\(\\$left\\).*\\|\\|.*! is_int\\(\\$right\\) && ! is_float\\(\\$right\\).*"
            ]
        },
    },
    minMsi: 0,
    minCoveredMsi: 0,
    testFramework: "phpunit",
    tmpDir: "build/infection",
}
